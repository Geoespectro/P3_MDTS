partir de PNG\&quot;)]\n        SALTEMP[(\&quot;CSV temporal\&quot;)]\n    end\n\n    S3 --&gt; DESC\n    SETUP --&gt; DESC\n    DESC --&gt; BANDAS\n\n    BANDAS --&gt; VAL\n    VAL -. \&quot;actualiza estado\&quot; .-&gt; ESTADO\n\n    VAL --&gt; REM\n    CR --&gt; REM\n    REM --&gt; CONV\n    CONV --&gt; ALG\n    ALG --&gt; RGB\n\n    RGB --&gt; MAPA\n    CM --&gt; MAPA\n    GEO --&gt; MAPA\n    MAPA --&gt; PNG\n    PNG --&gt; GIFPROC\n    GIFPROC --&gt; GIF\n\n    BANDAS -. \&quot;archivo NetCDF B13\&quot; .-&gt; DB13\n    DB13 --&gt; SALB13\n\n    PNG -. \&quot;ejecución separada\&quot; .-&gt; DTEMP\n    DTEMP --&gt; SALTEMP\n\n    classDef fuente fill:#dbeafe,stroke:#2563eb,stroke-width:2px,color:#111827\n    classDef descarga fill:#dcfce7,stroke:#16a34a,stroke-width:2px,color:#111827\n    classDef control fill:#fef3c7,stroke:#d97706,stroke-width:2px,color:#111827\n    classDef proceso fill:#ede9fe,stroke:#7c3aed,stroke-width:2px,color:#111827\n    classDef producto fill:#cffafe,stroke:#0891b2,stroke-width:2px,color:#111827\n    classDef diagnostico fill:#fee2e2,stroke:#dc2626,stroke-width:2px,color:#111827\n\n    class S3,SETUP,CR,CM,GEO fuente\n    class DESC,BANDAS descarga\n    class VAL,ESTADO control\n    class REM,CONV,ALG,RGB proceso\n    class MAPA,PNG,GIFPROC,GIF producto\n    class DB13,SALB13,DTEMP,SALTEMP diagnostico&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="1zQlT789vA7VxuupXaWy-1">
